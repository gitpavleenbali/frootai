{
  "name": "frootai",
  "displayName": "FrootAI — From the Roots to the Fruits",
  "description": "The open glue binding Infrastructure, Platform & Application teams with the GenAI ecosystem. Standalone engine: 16 modules, 200+ terms, 20 solution plays, 22 MCP tools — works from any workspace.",
  "version": "1.3.1",
  "publisher": "pavleenbali",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Education",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "ai",
    "architecture",
    "azure",
    "mcp",
    "agents",
    "rag",
    "copilot",
    "frootai",
    "solution-plays",
    "devkit",
    "tunekit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gitpavleenbali/frootai"
  },
  "homepage": "https://frootai.dev",
  "bugs": {
    "url": "https://github.com/gitpavleenbali/frootai/issues"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frootai-sidebar",
          "title": "FrootAI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "frootai-sidebar": [
        {
          "id": "frootai.solutionPlays",
          "name": "🎯 Solution Plays (20)"
        },
        {
          "id": "frootai.mcpTools",
          "name": "🔌 MCP Tools (22)"
        },
        {
          "id": "frootai.frootModules",
          "name": "FAI Knowledge Hub (18 modules)"
        },
        {
          "id": "frootai.glossary",
          "name": "📖 AI Glossary (200+ terms)"
        }
      ]
    },
    "commands": [
      {
        "command": "frootai.browseSolutionPlays",
        "title": "FrootAI: Browse Solution Plays"
      },
      {
        "command": "frootai.lookupTerm",
        "title": "FrootAI: Look Up AI Term"
      },
      {
        "command": "frootai.searchKnowledge",
        "title": "FrootAI: Search Knowledge Base"
      },
      {
        "command": "frootai.openSetupGuide",
        "title": "FrootAI: Open Setup Guide"
      },
      {
        "command": "frootai.openSolutionPlay",
        "title": "FrootAI: Open Solution Play"
      },
      {
        "command": "frootai.initDevKit",
        "title": "FrootAI: Initialize DevKit (Full .github Agentic OS)"
      },
      {
        "command": "frootai.showArchitecturePattern",
        "title": "FrootAI: Show Architecture Pattern"
      },
      {
        "command": "frootai.initHooks",
        "title": "FrootAI: Initialize Hooks (guardrails.json)"
      },
      {
        "command": "frootai.initPrompts",
        "title": "FrootAI: Initialize Prompt Files (slash commands)"
      },
      {
        "command": "frootai.initTuneKit",
        "title": "FrootAI: Initialize TuneKit (config + evaluation + infra)"
      },
      {
        "command": "frootai.initSpecKit",
        "title": "FrootAI: Initialize SpecKit (spec + WAF alignment)"
      },
      {
        "command": "frootai.installMcpServer",
        "title": "FrootAI: Install MCP Server (npm)"
      },
      {
        "command": "frootai.startMcpServer",
        "title": "FrootAI: Start MCP Server"
      },
      {
        "command": "frootai.configureMcp",
        "title": "FrootAI: Configure MCP (add .vscode/mcp.json)"
      },
      {
        "command": "frootai.autoChainAgents",
        "title": "FrootAI: Auto-Chain Agents (Build → Review → Tune)"
      },
      {
        "command": "frootai.quickCostEstimate",
        "title": "FrootAI: Quick Cost Estimate"
      },
      {
        "command": "frootai.validateConfig",
        "title": "FrootAI: Validate Config"
      },
      {
        "command": "frootai.installPlugin",
        "title": "FrootAI: Install Community Plugin"
      },
      {
        "command": "frootai.runEvaluation",
        "title": "FrootAI: Run Evaluation"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "frootai.browseSolutionPlays",
          "when": "view == frootai.solutionPlays",
          "group": "navigation"
        },
        {
          "command": "frootai.installMcpServer",
          "when": "view == frootai.mcpTools",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "frootai.initDevKit",
          "when": "view == frootai.solutionPlays",
          "group": "1_init@1"
        },
        {
          "command": "frootai.initTuneKit",
          "when": "view == frootai.solutionPlays",
          "group": "1_init@2"
        },
        {
          "command": "frootai.initHooks",
          "when": "view == frootai.solutionPlays",
          "group": "1_init@3"
        },
        {
          "command": "frootai.initPrompts",
          "when": "view == frootai.solutionPlays",
          "group": "1_init@4"
        },
        {
          "command": "frootai.installMcpServer",
          "when": "view == frootai.mcpTools",
          "group": "1_mcp@1"
        },
        {
          "command": "frootai.startMcpServer",
          "when": "view == frootai.mcpTools",
          "group": "1_mcp@2"
        },
        {
          "command": "frootai.configureMcp",
          "when": "view == frootai.mcpTools",
          "group": "1_mcp@3"
        }
      ]
    },
    "configuration": {
      "title": "FrootAI",
      "properties": {
        "frootai.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the FrootAI MCP server (index.js). Leave empty to use npx frootai-mcp."
        },
        "frootai.solutionPlaysPath": {
          "type": "string",
          "default": "",
          "description": "Path to the solution-plays directory. Leave empty for auto-detect."
        }
      }
    }
  },
  "scripts": {
    "compile": "node src/extension.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0"
  }
}
