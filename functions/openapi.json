{
  "openapi": "3.1.0",
  "info": {
    "title": "FrootAI Chatbot API",
    "version": "3.1.2",
    "description": "REST API for the FrootAI AI-powered chatbot — search plays, estimate costs, and chat with FAI Agent.",
    "contact": {
      "name": "FrootAI",
      "url": "https://frootai.dev"
    },
    "license": {
      "name": "MIT",
      "url": "https://github.com/gitpavleenbali/frootai/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://frootai-chatbot-api.azurewebsites.net",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check",
        "description": "Returns service status, model name, and tool count.",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "frootai-chatbot-api" },
                    "model": { "type": "string", "example": "gpt-4o-mini" },
                    "tools": { "type": "integer", "example": 22 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/search-plays": {
      "post": {
        "operationId": "searchPlays",
        "summary": "Search solution plays",
        "description": "Search across 20 FrootAI solution plays by keyword. Returns matching plays with name, complexity, and URL.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": { "type": "string", "example": "RAG architecture", "description": "Search term to match against play names and descriptions" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching plays",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "number": { "type": "string" },
                          "name": { "type": "string" },
                          "complexity": { "type": "string" },
                          "url": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/estimate-cost": {
      "post": {
        "operationId": "estimateCost",
        "summary": "Estimate Azure costs",
        "description": "Returns a monthly Azure cost estimate for a solution play at dev or prod scale.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["play"],
                "properties": {
                  "play": { "type": "string", "example": "01-enterprise-rag" },
                  "scale": { "type": "string", "enum": ["dev", "prod"], "default": "dev" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cost estimate",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "play": { "type": "string" },
                    "scale": { "type": "string" },
                    "estimate": { "type": "string" },
                    "breakdown": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "service": { "type": "string" },
                          "cost": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "operationId": "chat",
        "summary": "Chat with FAI Agent",
        "description": "Send a message to the FAI Agent chatbot. Returns the complete AI response.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": { "type": "string", "example": "What is RAG architecture?" },
                  "history": {
                    "type": "array",
                    "description": "Previous conversation messages for context",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string", "enum": ["user", "assistant"] },
                        "content": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reply": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/chat/stream": {
      "post": {
        "operationId": "chatStream",
        "summary": "Chat with FAI Agent (streaming)",
        "description": "Send a message and receive a streaming Server-Sent Events response. Each event contains a text chunk.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": { "type": "string" },
                  "history": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string" },
                        "content": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming SSE response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "Server-Sent Events stream. Each event: data: {\"chunk\":\"text\"} or data: [DONE]"
                }
              }
            }
          }
        }
      }
    }
  }
}
